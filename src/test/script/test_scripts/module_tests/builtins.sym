println("=== Test copy() ===")
orig_list = list(1, 2, 3)
copied_list = copy(orig_list)
println(orig_list)
println(copied_list)

println("=== Test len() ===")
test_list = list(1, 2, 3, 4, 5)
println(len(test_list))
empty_list = list()
println(len(empty_list))

println("=== Test list() ===")
new_list = list(10, 20, 30)
println(new_list)
empty = list()
println(empty)

println("=== Test list_get() and list_set() ===")
my_list = list(100, 200, 300)
println(list_get(my_list, 0))
println(list_get(my_list, 1))
println(list_get(my_list, 2))
list_set(my_list, 1, 999)
println(my_list)

println("=== Test append() ===")
append_list = list(1, 2, 3)
append(append_list, 4)
println(append_list)
append(append_list, 5)
append(append_list, 6)
println(append_list)

println("=== Test pop() ===")
pop_list = list(10, 20, 30, 40, 50)
popped = pop(pop_list)
println(popped)
println(pop_list)
popped = pop(pop_list)
println(popped)
println(pop_list)

println("=== Test slice() ===")
slice_list = list(1, 2, 3, 4, 5, 6, 7, 8)
sliced1 = slice(slice_list, 0, 3)
println(sliced1)
sliced2 = slice(slice_list, 2, 5)
println(sliced2)
sliced3 = slice(slice_list, 0, 0)
println(sliced3)
sliced4 = slice(slice_list, 5, 8)
println(sliced4)

println("=== Test dict() ===")
my_dict = dict()
println(my_dict)

println("=== Test dict_set() and dict_get() ===")
d = dict()
dict_set(d, "name", "Alice")
dict_set(d, "age", 30)
dict_set(d, "city", "NYC")
println(dict_get(d, "name"))
println(dict_get(d, "age"))
println(dict_get(d, "city"))

println("=== Test dict_has_key() ===")
test_dict = dict()
dict_set(test_dict, "present", 42)
println(dict_has_key(test_dict, "present"))
println(dict_has_key(test_dict, "missing"))

println("=== Test assignment vs copy for lists ===")
list_a = list(1, 2, 3)
list_b = list_a
list_b[0] = 99
println(list_a)
println(list_b)
list_c = list(10, 20, 30)
list_d = copy(list_c)
list_d[0] = 88
println(list_c)
println(list_d)

println("=== Test assignment vs copy for dicts ===")
dict_a = dict()
dict_set(dict_a, "key1", "value1")
dict_b = dict_a
dict_set(dict_b, "key1", "modified")
println(dict_get(dict_a, "key1"))
println(dict_get(dict_b, "key1"))
dict_c = dict()
dict_set(dict_c, "key2", "original")
dict_d = copy(dict_c)
dict_set(dict_d, "key2", "changed")
println(dict_get(dict_c, "key2"))
println(dict_get(dict_d, "key2"))

println("=== Test nested lists and dicts ===")
nested_list = list(list(1, 2), list(3, 4, 5))
println(nested_list)
println(list_get(nested_list, 0))
nested_dict = dict()
dict_set(nested_dict, "list_key", list(100, 200))
dict_set(nested_dict, "number_key", 42)
println(dict_get(nested_dict, "list_key"))
println(dict_get(nested_dict, "number_key"))

println("=== Test combining operations ===")
combined_list = list(10, 20, 30)
append(combined_list, 40)
combined_list[0] = 5
sliced = slice(combined_list, 1, 3)
println(sliced)
popped_val = pop(combined_list)
println(popped_val)
println(combined_list)

println("=== Test comparison operators ===")
println(eq(5, 5))
println(eq(5, 3))
println(neq(5, 3))
println(neq(5, 5))
println(lt(2, 5))
println(lt(5, 2))
println(lte(5, 5))
println(lte(5, 3))
println(gt(5, 2))
println(gt(2, 5))
println(gte(5, 5))
println(gte(3, 5))

println("=== Test equality with different types ===")
println(eq("hello", "hello"))
println(eq("hello", "world"))
println(neq("hello", "world"))
println(neq("hello", "hello"))

println("=== Test boolean operators ===")
println(and(true, true))
println(and(true, false))
println(and(false, true))
println(and(false, false))

println("=== Test or operator ===")
println(or(true, true))
println(or(true, false))
println(or(false, true))
println(or(false, false))

println("=== Test xor operator ===")
println(xor(true, true))
println(xor(true, false))
println(xor(false, true))
println(xor(false, false))

println("=== Test nand operator ===")
println(nand(true, true))
println(nand(true, false))
println(nand(false, true))
println(nand(false, false))

println("=== Test nor operator ===")
println(nor(true, true))
println(nor(true, false))
println(nor(false, true))
println(nor(false, false))

println("=== Test not operator ===")
println(not(true))
println(not(false))

println("=== Test infix comparison operators ===")
println(5 == 5)
println(5 != 3)
println(2 < 5)
println(5 <= 5)
println(5 > 2)
println(5 >= 5)

println("=== Test infix boolean operators ===")
println(true && true)
println(true || false)
println(!false)
